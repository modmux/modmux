{
  "name": "@modmux/cli",
  "version": "0.6.0",
  "license": "MIT",
  "exports": {
    ".": "./src/main.ts"
  },
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@^1.1.0",
    "@cliffy/keypress": "jsr:@cliffy/keypress@^1.1.0",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.10",
    "@std/path": "jsr:@std/path@^1.1.4"
  },
  "tasks": {
    "install": "deno install --global --allow-all --config deno.json -n modmux --force src/main.ts",
    "dev": "deno run -A src/main.ts",
    "compile": "deno compile --allow-net --allow-env --allow-run --allow-read --allow-write --allow-ffi --output ../../bin/modmux src/main.ts"
  }
}
