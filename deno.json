{
  "name": "@myty/claudio",
  "version": "0.1.0",
  "exports": {
    ".": "./src/cli/main.ts"
  },
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/path": "jsr:@std/path@1"
  },
  "tasks": {
    "dev": "deno run -A --watch src/cli/main.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "quality": "deno lint && deno fmt --check && deno check && deno test --allow-all",
    "sync-version": "deno run -A scripts/sync-version.ts",
    "compile": "deno compile --allow-net --allow-env --allow-run --allow-read --allow-write --output bin/claudio src/cli/main.ts"
  }
}
