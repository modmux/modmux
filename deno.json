{
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.19"
  },
  "tasks": {
    "dev": "deno run -A --watch src/cli/main.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "quality": "deno lint && deno fmt --check && deno check && deno test --allow-run --allow-net --allow-env"
  }
}
