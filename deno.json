{
  "version": "0.7.1",
  "license": "MIT",
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@^1.2.1",
    "@cliffy/keypress": "jsr:@cliffy/keypress@^1.2.1",
    "@cross/service": "jsr:@cross/service@^1.0.7",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.32",
    "@std/fmt": "jsr:@std/fmt@^1.0.10",
    "@std/path": "jsr:@std/path@^1.1.6",
    "@std/toml": "jsr:@std/toml@^1.0.11",
    "@std/yaml": "jsr:@std/yaml@^1.1.2"
  },
  "lint": {
    "exclude": ["scripts/", "site/"]
  },
  "fmt": {
    "exclude": ["./specs", "./.agents"]
  },
  "tasks": {
    "install": "deno run -A scripts/install-from-source.ts",
    "dev": "deno run -A cli/src/main.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check cli/src/**/*.ts gateway/src/**/*.ts providers/src/**/*.ts tests/**/*.ts",
    "quality": "deno lint && deno fmt --check && deno check && deno test --allow-all",
    "compile": "deno run -A scripts/compile.ts"
  },
  "workspace": ["cli", "gateway", "providers"]
}
