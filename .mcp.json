{
  "mcpServers": {
    "lean-spec": {
      "args": [
        "-y",
        "@leanspec/mcp"
      ],
      "command": "npx"
    },
    "github": {
      "command": "deno",
      "args": [
        "run",
        "-A",
        "./scripts/github-mcp.ts"
      ],
      "transport": "stdio"
    }
  }
}
